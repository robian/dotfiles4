#!/bin/sh
# mise config hash: {{ include "dot_config/mise/config.toml" | sha256sum }}
set -eu

export PATH="$HOME/.local/bin:$HOME/.local/share/mise/shims:$PATH"

if command -v codex >/dev/null 2>&1; then
  echo "dotfiles: codex is already installed."
  exit 0
fi

if ! command -v mise >/dev/null 2>&1; then
  echo "dotfiles: mise is not installed; skipping Codex CLI install."
  exit 0
fi

npm="$(mise which npm 2>/dev/null || true)"
node="$(mise which node 2>/dev/null || true)"

if [ -z "$npm" ] || [ -z "$node" ]; then
  echo "dotfiles: node/npm unavailable; skipping Codex CLI install."
  exit 0
fi

export PATH="$(dirname "$node"):$PATH"

echo "dotfiles: installing Codex CLI."
"$npm" install --global --prefix "$HOME/.local" @openai/codex
